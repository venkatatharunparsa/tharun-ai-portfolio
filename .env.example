# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# LLM Providers (fallback keys optional — used when primary hits quota/rate limits)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_KEY_FALLBACK=your_second_gemini_api_key
GROQ_API_KEY=your_groq_api_key
GROQ_API_KEY_FALLBACK=your_second_groq_api_key

# Voice
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id

# Memory
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Monitoring
LANGSMITH_API_KEY=your_langsmith_api_key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=tharun-portfolio

# App
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ADMIN_SECRET=create_a_strong_secret_here
